{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact-evidence-registry.schema.json",
  "title": "Artifact Evidence Registry",
  "type": "object",
  "required": ["registry_version", "artifacts"],
  "properties": {
    "registry_version": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "type", "related_stage", "status"],
        "properties": {
          "artifact_id": { "type": "string" },
          "type": { "type": "string" },
          "related_stage": { "type": "string" },
          "related_stage_output": { "type": "string" },
          "related_ticket_ids": { "type": "array" },
          "related_validation_ids": { "type": "array" },
          "related_agent_ids": { "type": "array" },
          "path_or_url": { "type": "string" },
          "status": { "type": "string" },
          "confidence": { "type": "string" },
          "created_by": { "type": "string" },
          "created_at": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
