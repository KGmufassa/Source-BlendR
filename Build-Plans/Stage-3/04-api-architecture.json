  "api_risks": [
    {
      "id": "ARCH-RISK-007",
      "risk": "External sharing links may expose customer-specific pricing.",
      "severity": "high",
      "mitigation": "Use expiring signed links, access tokens, audit events, and revocation."
    },
    {
      "id": "ARCH-RISK-008",
      "risk": "Pricing preview endpoints can become performance hotspots.",
      "severity": "medium",
      "mitigation": "Cache deterministic calculations and snapshot approved prices."
    }
  ],
  "architecture_decisions": [
    {
      "id": "ADR-007",
      "decision": "Do not expose a public integration API in MVP.",
      "status": "accepted",
      "rationale": "Stage 2 did not validate external API demand; internal APIs are enough for Stage 4 and Stage 5."
    },
    {
      "id": "ADR-008",
      "decision": "Use command-style operations for workflow transitions.",
      "status": "accepted",
      "rationale": "Imports, quote approval, document generation, and pricing snapshots are workflows, not generic CRUD updates."
    }
  ],
